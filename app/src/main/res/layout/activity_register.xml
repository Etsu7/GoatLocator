<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F5F0E8">

    <ImageView
        android:id="@+id/ivGoatPhoto"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="40dp"
        android:src="@drawable/goat"
        android:scaleType="centerCrop"
        android:background="#E0D5C5"
        android:contentDescription="Photo de la chèvre" />

    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:padding="12dp"
        android:text="@string/no_location"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#6D4C41" />

    <Button
        android:id="@+id/btnLocateGoat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:padding="16dp"
        android:text="@string/btn_locate"
        android:textSize="16sp"
        android:backgroundTint="#6D4C41"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnTakePhoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/btn_photo"
        android:textSize="16sp"
        android:backgroundTint="#6D4C41"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:padding="16dp"
        android:text="@string/btn_save"
        android:textSize="16sp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="16dp"
        android:text="@string/btn_back"
        android:textSize="16sp"
        android:backgroundTint="#9E9E9E"
        android:textColor="#FFFFFF" />

</LinearLayout>